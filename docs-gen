#!/bin/bash

set -euo pipefail

if [ -z "${1:-}" ]; then
    echo "provide a path to the params file."
    exit
fi

if [ -z "${2:-}" ]; then
    echo "provide the file to run fact check pass against."
    exit
fi

PROMPT=$1
FACT_CHECK_FILE=$2

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

VENV_DIR="$SCRIPT_DIR/.venv"

PROMPT_TEXT=$("$VENV_DIR/bin/python" "$SCRIPT_DIR/create_tutorial_prompt.py" --template "$SCRIPT_DIR/examples/user_prompts/documentation.txt" --params "$PROMPT")

"$VENV_DIR/bin/python" "$SCRIPT_DIR/src/interface/streaming_client.py" \
    -s "$SCRIPT_DIR/examples/system_prompts/coding_agent.txt" \
    -w "$PWD" \
    -p "$PROMPT_TEXT"


echo "Performing fact checking and fixing any bugs found..."

"$VENV_DIR/bin/python" "$SCRIPT_DIR/src/interface/streaming_client.py" \
    -s "$SCRIPT_DIR/examples/system_prompts/coding_agent.txt" \
    -w "$PWD" \
    -p "You wrote the following document in this directory: $FACT_CHECK_FILE. Perform a thorough pass on it looking for: misinformation, syntax errors in the document structurally, syntax errors on any diagrams and code blocks. Create a backup of the file first before editing. Name the backup with a prefixed underscore of the original name. Ex. a.html -> _a.html. Final output should be same name as original."